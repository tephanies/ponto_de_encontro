<Window x:Class="PontoDeEncontro.ConnectionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurar Conexão com o Banco" Height="580" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <!-- Estilo dos campos de texto -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
                </Setter>
        </Style>

        <Style x:Key="RefreshButton" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#2E7D32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E8F5E9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F5F5F5" CornerRadius="16" BorderBrush="#E0E0E0" BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="Black"/>
        </Border.Effect>

        <Grid Margin="32,24,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título e botão fechar -->
            <DockPanel Grid.Row="0" Margin="0,0,0,4">
                <Button DockPanel.Dock="Right" Content="✕" FontSize="18" FontWeight="Light"
                        Background="Transparent" BorderThickness="0" Width="32" Height="32"
                        Cursor="Hand" Click="BtnCancelar_Click" VerticalAlignment="Top"
                        Foreground="#888888"/>
                <TextBlock Text="Configurar Conexão com o Banco" FontSize="20" FontWeight="Bold"
                           Foreground="#333333"/>
            </DockPanel>

            <TextBlock Grid.Row="1" Text="Informe os dados de conexao para liberar o sistema no cliente."
                       FontSize="13" Foreground="#777777" Margin="0,0,0,20" TextWrapping="Wrap"/>

            <!-- Servidor -->
            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <TextBlock Text="Servidor" FontSize="13" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtServer" Style="{StaticResource ModernTextBox}" TextChanged="ConnectionField_Changed"/>
            </StackPanel>

            <!-- Usuário -->
            <StackPanel Grid.Row="3" Margin="0,0,0,12">
                <TextBlock Text="Usuário" FontSize="13" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtUser" Style="{StaticResource ModernTextBox}" TextChanged="ConnectionField_Changed"/>
            </StackPanel>

            <!-- Senha -->
            <StackPanel Grid.Row="4" Margin="0,0,0,0">
                <TextBlock Text="Senha" FontSize="13" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,4"/>
                <PasswordBox x:Name="TxtPassword" Style="{StaticResource ModernPasswordBox}" PasswordChanged="TxtPassword_PasswordChanged"/>
            </StackPanel>

            <!-- Banco de Dados -->
            <StackPanel Grid.Row="6" Margin="0,0,0,12">
                <TextBlock Text="Banco de Dados:" FontSize="13" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="CmbDatabase" Grid.Column="0" Style="{StaticResource ModernComboBox}" IsEditable="True"/>
                    <Button Grid.Column="1" Content="🔄" Style="{StaticResource RefreshButton}"
                            Margin="6,0,0,0" ToolTip="Carregar bancos de dados"
                            Click="BtnCarregarBancos_Click"/>
                </Grid>
            </StackPanel>

            <!-- Status -->
            <Border Grid.Row="7" Background="#EDF7ED" CornerRadius="8" Padding="14,10" Margin="0,0,0,20">
                <TextBlock x:Name="TxtStatus" Text="Preencha os dados, teste a conexão e clique em Salvar."
                           TextWrapping="Wrap" FontSize="13" Foreground="#555555"/>
            </Border>

            <!-- Botões -->
            <Grid Grid.Row="9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{StaticResource ModernButton}"
                        BorderBrush="#2E7D32" Foreground="#2E7D32" Margin="0,0,6,0"
                        Click="BtnTestarConexao_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔌" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="Testar Conexão"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Style="{StaticResource ModernButton}"
                        BorderBrush="#1565C0" Foreground="#1565C0" Margin="6,0,6,0"
                        Click="BtnSalvarEntrar_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✔" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="Salvar"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2" Style="{StaticResource ModernButton}"
                        BorderBrush="#C62828" Foreground="#C62828" Margin="6,0,0,0"
                        Click="BtnCancelar_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✕" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="Cancelar"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
