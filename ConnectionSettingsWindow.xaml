<Window x:Class="PontoDeEncontro.ConnectionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurar conexao com o banco" Height="360" Width="460"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Informe os dados de conexao para liberar o sistema no cliente."
                   FontWeight="SemiBold" Margin="0,0,0,18" TextWrapping="Wrap"/>

        <TextBlock Grid.Row="1" Text="Servidor:" VerticalAlignment="Center" Margin="0,0,12,10"/>
        <TextBox x:Name="TxtServer" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Text="Banco de dados:" VerticalAlignment="Center" Margin="0,0,12,10"/>
        <TextBox x:Name="TxtDatabase" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10"/>

        <CheckBox x:Name="ChkIntegratedSecurity" Grid.Row="3" Grid.ColumnSpan="2"
                  Content="Usar autenticacao integrada do Windows"
                  Margin="0,0,0,12" Checked="ChkIntegratedSecurity_Changed" Unchecked="ChkIntegratedSecurity_Changed"/>

        <TextBlock Grid.Row="4" Text="Usuario:" VerticalAlignment="Center" Margin="0,0,12,10"/>
        <TextBox x:Name="TxtUser" Grid.Row="4" Grid.Column="1" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="5" Text="Senha:" VerticalAlignment="Center" Margin="0,0,12,10"/>
        <PasswordBox x:Name="TxtPassword" Grid.Row="5" Grid.Column="1" Margin="0,0,0,10"/>

        <Border Grid.Row="6" Grid.ColumnSpan="2" Background="#FFF4F4F4" CornerRadius="8" Padding="12" Margin="0,4,0,16">
            <TextBlock x:Name="TxtStatus" Text="Preencha os dados, teste a conexao e clique em Salvar e Entrar."
                       TextWrapping="Wrap"/>
        </Border>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Testar conexao" Width="120" Margin="0,0,8,0" Click="BtnTestarConexao_Click"/>
            <Button Content="Salvar e Entrar" Width="120" Margin="0,0,8,0" Click="BtnSalvarEntrar_Click"/>
            <Button Content="Cancelar" Width="90" Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>
