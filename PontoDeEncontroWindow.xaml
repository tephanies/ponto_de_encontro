<Window x:Class="PontoDeEncontro.PontoDeEncontroWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ponto de Encontro" Height="700" Width="1350"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============ TOPO ESQUERDO ============ -->
        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="Empresa:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbEmpresa" Width="400" SelectionChanged="CmbEmpresa_SelectionChanged"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PIN:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="txtPin" Width="150" Margin="0,0,16,0"/>
                <TextBlock Text="Nome:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="txtNome" Width="250" Margin="0,0,8,0"/>
                <Button Content="Buscar" Width="60" Click="BtnBuscar_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- ============ TOPO DIREITO ============ -->
        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="Ponto de Encontro:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbPontoEncontro" Width="300" SelectionChanged="CmbPontoEncontro_SelectionChanged"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Pontos de Encontro Ativos" VerticalAlignment="Top" Margin="0,0,8,0"/>
                <ListBox x:Name="lstPontosAtivos" Width="200" Height="60"/>
            </StackPanel>
        </StackPanel>

        <!-- ============ CONTEÚDO PRINCIPAL ============ -->
        <!-- Esquerda: detalhe pessoa selecionada + grid Área Interna -->
        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Card detalhe pessoa esquerda -->
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <Image x:Name="imgPessoaEsq" Width="120" Height="120" Stretch="Uniform" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock><Run FontWeight="Bold" Text="PIN: "/><Run x:Name="txtDetPinEsq"/></TextBlock>
                        <TextBlock><Run FontWeight="Bold" Text="Nome: "/><Run x:Name="txtDetNomeEsq"/></TextBlock>
                        <TextBlock><Run FontWeight="Bold" Text="Ramal: "/><Run x:Name="txtDetRamalEsq"/></TextBlock>
                        <TextBlock><Run FontWeight="Bold" Text="Celular: "/><Run x:Name="txtDetCelularEsq"/></TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Grid Área Interna -->
            <DockPanel Grid.Row="1">
                <TextBlock DockPanel.Dock="Top" x:Name="lblTotalAreaInterna" Text="Total de Pessoas: 0"
                           FontWeight="Bold" Margin="0,0,0,4"/>
                <DataGrid x:Name="dgAreaInterna" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionChanged="DgAreaInterna_SelectionChanged" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PIN" Binding="{Binding Pin}" Width="150"/>
                        <DataGridTextColumn Header="Nome" Binding="{Binding PesNome}" Width="*"/>
                        <DataGridTextColumn Header="Ramal" Binding="{Binding PesRamalCom}" Width="100"/>
                        <DataGridTextColumn Header="Celular" Binding="{Binding PesCelular}" Width="120"/>
                        <DataGridTextColumn Header="Ambiente" Binding="{Binding AmbNumero}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>

        <!-- Direita: detalhe pessoa selecionada + grid Ponto de Encontro -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Card detalhe pessoa direita -->
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <Image x:Name="imgPessoaDir" Width="120" Height="120" Stretch="Uniform" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock><Run FontWeight="Bold" Text="PIN: "/><Run x:Name="txtDetPinDir"/></TextBlock>
                        <TextBlock><Run FontWeight="Bold" Text="Nome: "/><Run x:Name="txtDetNomeDir"/></TextBlock>
                        <TextBlock><Run FontWeight="Bold" Text="Ramal: "/><Run x:Name="txtDetRamalDir"/></TextBlock>
                        <TextBlock><Run FontWeight="Bold" Text="Celular: "/><Run x:Name="txtDetCelularDir"/></TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Grid Ponto de Encontro -->
            <DockPanel Grid.Row="1">
                <TextBlock DockPanel.Dock="Top" x:Name="lblTotalPontoEncontro" Text="Pessoas no Ponto de Encontro: 0"
                           FontWeight="Bold" Margin="0,0,0,4"/>
                <DataGrid x:Name="dgPontoEncontro" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionChanged="DgPontoEncontro_SelectionChanged" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PIN" Binding="{Binding Pin}" Width="150"/>
                        <DataGridTextColumn Header="Nome" Binding="{Binding PesNome}" Width="*"/>
                        <DataGridTextColumn Header="Ramal" Binding="{Binding PesRamalCom}" Width="100"/>
                        <DataGridTextColumn Header="Celular" Binding="{Binding PesCelular}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>

        <!-- ============ RODAPÉ ============ -->
        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,8,0,0">
            <CheckBox x:Name="chkAutoAtualizar" Content="Atualização automática" IsChecked="True"
                      Checked="ChkAutoAtualizar_Changed" Unchecked="ChkAutoAtualizar_Changed"
                      VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="🔄 Limpar" Width="100" Margin="0,0,8,0" Click="BtnLimpar_Click"/>
            <Button Content="🔃 Atualizar" Width="100" Margin="0,0,8,0" Click="BtnAtualizar_Click"/>
            <Button Content="❌ Sair" Width="100" Click="BtnSair_Click"/>
        </StackPanel>

        <!-- Barra de status -->
        <StatusBar Grid.Row="3" Grid.ColumnSpan="2" Margin="0,4,0,0">
            <TextBlock x:Name="txtStatus" Text="Pronto"/>
        </StatusBar>
    </Grid>
</Window>
